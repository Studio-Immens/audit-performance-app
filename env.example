# ============================================
# STUDIO IMMENS AUDIT PROXY - CONFIGURAZIONE
# ============================================

# Google PageSpeed Insights API Key
# Ottienila gratuitamente su: https://developers.google.com/speed/docs/insights/v5/get-started
PSI_API_KEY=your_psi_api_key_here

# Allowed Origins (CORS) - separa con virgole
ALLOWED_ORIGINS=https://studioimmens.com,https://www.studioimmens.com

# Node Environment
NODE_ENV=production

# Port (CapRover gestisce questo automaticamente)
PORT=3000
